            <uq:ObservedVariable name="outletTemp" />
            <uq:ObservedVariable name="inletTemp" />
         </uq:ObservedVariables>
         <uq:ResultSet>
            <uq:Results point="P1">
               <uq:ErrorMetric type="relativeError" value="0.295" />
               <uq:ErrorMetric type="relativeError" value="0.292" />
            </uq:Results>
            <uq:Results point="P2">
               <uq:ErrorMetric type="relativeError" value="0.293" />
