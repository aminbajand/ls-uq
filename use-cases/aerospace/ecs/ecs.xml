                     type="application/xml"
                  />
               </uq:Boundary>
               <uq:ExperimentPoints>
                  <uq:PointSet id="val_01_exps_01">
                     <uq:Points>
                        <uq:Point coordinates="100 0.004" id="P1" />
                        <uq:Point coordinates="1720 0.58" id="P2" />
